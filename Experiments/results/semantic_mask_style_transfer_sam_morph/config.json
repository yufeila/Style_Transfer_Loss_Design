    "mask_dir": "/data1/yyf/Style_Transfer_Loss_Design/masks/sam_bridge_morph_1024",
    "source": "Content and style masks use prompt-guided SAM ViT-H masks. The content bridge mask includes constrained morphology completion for cables. SAM labels bridge and building are merged into bridge_building for the masked Gram style loss.",
    "region_weights": {
      "sky": 1.0,
      "water": 1.0,
      "bridge_building": 1.0,
      "mountain_land": 1.0
    }
  },
  "save_every": 300,
  "seed": 42,
  "device": "cuda"
